# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
.report/

# Compiled output
dist/
build/
*.tsbuildinfo

# Dependency directories
node_modules/

# Environment variables
.env
.env*.local
.env.development.local
.env.test.local
.env.production.local

# Editor directories and files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.bak
*.user
*.pdb
*.orig

# Prisma
# Exclude Prisma generated client directory
# Note: the client is generated into node_modules/@prisma/client by default
# which is already ignored by node_modules/
# If you changed the output directory, uncomment the line below and adjust the path:
# prisma/generated/

# Local database files (if any, e.g., SQLite)
*.db
*.sqlite
*.sqlite-journal

# Coverage directory
coverage/

# Backend specific ignores
backend/dist/
backend/node_modules/
backend/.env
backend/.env.*
backend/*.tsbuildinfo
backend/coverage/
backend/*.log

# Aider specific ignores
.aider*
