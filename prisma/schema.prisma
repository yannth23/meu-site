datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id @default(cuid())
  email      String     @unique
  password   String
  name       String?
  verified   Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  favoriteTeams FavoriteTeam[]
  preferences UserPreference?
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model FavoriteTeam {
  id       String   @id @default(cuid())
  userId   String
  teamName String
  user     User     @relation(fields: [userId], references: [id])
}

model UserPreference {
  id                         String    @id @default(cuid())
  userId                     String    @unique
  receiveDailyNotifications  Boolean   @default(true)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  user                       User      @relation(fields: [userId], references: [id])
}

model FootballMatch {
  id           String   @id @default(cuid())
  date         DateTime
  championship String
  team1        String
  team2        String
  status       String
  externalId   String?  @unique // To store ID from external API and prevent duplicates
}
