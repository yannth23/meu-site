datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String
  favoriteTeams FavoriteTeam[]
}

model FavoriteTeam {
  id       String   @id @default(cuid())
  userId   String
  teamName String
  user     User     @relation(fields: [userId], references: [id])
}

model Game {
  id       String   @id @default(cuid())
  date     DateTime
  championship String
  team1    String
  team2    String
}
